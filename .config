# Target Hardware
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820v2=y

# Driver LAN & WiFi MTK (MT7621/7603/76x2)
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-basic-wolfssl=y

# Optimasi RAM 64MB (WAJIB)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# Web Interface & Aplikasi
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-proto-ppp=y

# EQOS sebagai Modul (ipk terpisah)
CONFIG_PACKAGE_luci-app-eqos=m

# Buang Paket Berat (Agar Flash 16MB Muat & RAM Lega)
# CONFIG_PACKAGE_luci-app-access-control is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-stats is not set

# Kompresi Output
CONFIG_TARGET_IMAGES_GZIP=y
